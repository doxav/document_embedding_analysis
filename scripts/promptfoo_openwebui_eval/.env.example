# Absolute path to your local document_embedding_analysis checkout
DEA_REPO_PATH=/absolute/path/to/document_embedding_analysis

# Container path for the mounted checkout. Keep this value when using docker-compose.yml.
DEA_REPO_ROOT=/workspace/document_embedding_analysis

# Open WebUI base URL reachable from Docker.
# docker-compose.yml uses Linux host networking so localhost is the host.
OPENWEBUI_BASE_URL=http://127.0.0.1:8080
OPENWEBUI_API_KEY=

# Use openwebui for the authenticated OpenWebUI API path.
# Use ollama to call a local Ollama server directly when OpenWebUI API auth is unavailable.
GENERATION_BACKEND=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen-laptop:latest
OLLAMA_MAX_SOURCE_CHARS=60000
OLLAMA_MAX_SOURCE_FILE_CHARS=6000

# Local OpenAI-compatible endpoint for Promptfoo model-graded assertions
# and the optional DEA qualitative judge. Ollama accepts any non-empty key.
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_API_KEY=ollama-local
OPENAI_MODEL=qwen-laptop-dea:latest
DEA_USE_JUDGE=true
DEA_JUDGE_MODEL=qwen-laptop-dea:latest

# Open WebUI pipe defaults
OPENWEBUI_PIPE_MODEL=summarizer---kohaku
OPENWEBUI_DEFAULT_SUMMARIZER_MODEL_ID=
OPENWEBUI_DEFAULT_ALGORITHM=
OPENWEBUI_DEFAULT_TARGET_LENGTH=long
OPENWEBUI_DEFAULT_STRUCTURE=
OPENWEBUI_INCLUDE_FILES_PAYLOAD=true
OPENWEBUI_TRIGGER_OUTLET=false

# Internal bridge defaults
OWUI_BRIDGE_HOST=0.0.0.0
OWUI_BRIDGE_PORT=8001

# Promptfoo
PROMPTFOO_DISABLE_TELEMETRY=1
HF_HOME=/workspace/promptfoo_openwebui_dea/.cache/huggingface
