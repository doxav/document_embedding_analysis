# Absolute path to your local document_embedding_analysis checkout
DEA_REPO_PATH=/absolute/path/to/document_embedding_analysis

# Container path for the mounted checkout. Keep this value when using docker-compose.yml.
DEA_REPO_ROOT=/workspace/document_embedding_analysis

# Open WebUI base URL reachable from Docker.
# docker-compose.yml uses Linux host networking so localhost is the host.
OPENWEBUI_BASE_URL=http://127.0.0.1:8080
OPENWEBUI_API_KEY=

# Summarization generation should use openwebui when evaluating the OpenWebUI
# summarization pipe/tool. Use openai_endpoint only for direct model baselines.
GENERATION_BACKEND=openwebui
OPENAI_ENDPOINT_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_ENDPOINT_API_KEY=local-endpoint
OPENAI_ENDPOINT_MODEL=qwen-laptop:latest
OPENAI_ENDPOINT_MAX_SOURCE_CHARS=60000
OPENAI_ENDPOINT_MAX_SOURCE_FILE_CHARS=6000

# OpenAI-compatible endpoint for Promptfoo model-graded assertions and the
# optional DEA qualitative judge.
# Local Ollama:
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_API_KEY=ollama-local
#
# Local vLLM:
# OPENAI_BASE_URL=http://127.0.0.1:8000/v1
# OPENAI_API_KEY=vllm-local
#
# OpenRouter:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-...
# OPENAI_MODEL=qwen/qwen3.6-35b-a3b
# DEA_JUDGE_MODEL=qwen/qwen3.6-35b-a3b
# DEA_JUDGE_EXTRA_BODY_JSON={"reasoning":{"enabled":false}}
#
# OpenAI:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_API_KEY=ollama-local
OPENAI_MODEL=qwen-laptop-dea:latest
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
DEA_USE_JUDGE=true
DEA_JUDGE_MODEL=qwen-laptop-dea:latest
DEA_JUDGE_EXTRA_BODY_JSON=

# Native DEA embedding backend. Keep this aligned with the embeddings used to
# build the DEA datasets. Changing it for existing datasets is expensive and
# can make scores incomparable unless the dataset embeddings are regenerated.
# Use openai only for a deliberately regenerated OpenAI-compatible DEA dataset.
DEA_EMBEDDING_BACKEND=hf
DEA_EMBEDDING_MODEL=

# Open WebUI pipe defaults
OPENWEBUI_PIPE_MODEL=summarizer---kohaku-OR
OPENWEBUI_DEFAULT_SUMMARIZER_MODEL_ID=
OPENWEBUI_DEFAULT_ALGORITHM=
OPENWEBUI_DEFAULT_TARGET_LENGTH=long
OPENWEBUI_DEFAULT_STRUCTURE=
OPENWEBUI_INCLUDE_FILES_PAYLOAD=true
OPENWEBUI_TRIGGER_OUTLET=false

# Internal bridge defaults
OWUI_BRIDGE_HOST=0.0.0.0
OWUI_BRIDGE_PORT=8001

# Promptfoo
PROMPTFOO_DISABLE_TELEMETRY=1
HF_HOME=/workspace/promptfoo_openwebui_dea/.cache/huggingface
